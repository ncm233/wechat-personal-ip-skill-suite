# Local secret file example for wechat-cover-image.
# Copy to .env and fill values. Do not commit .env.

GPTPROTO_API_KEY=your_gptproto_api_key_here
GPTPROTO_BASE_URL=https://gptproto.com/v1
WECHAT_COVER_MODEL=gpt-image-2

# Optional APiYi-compatible fallback:
# APIYI_API_KEY=your_apiyi_key_here
# APIYI_BASE_URL=https://api.apiyi.com/v1
